# ─── Banco de Dados ───────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_aqui
POSTGRES_DB=dbtestejunior
POSTGRES_PORT=5432

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3333
NODE_ENV=production
JWT_SECRET=troque_por_uma_chave_longa_e_aleatoria

# CORS — deve ser a URL de onde o frontend será acessado
FRONTEND_URL=http://localhost:5173

# ─── Conexão com o banco (usada fora do Docker) ───────────────────────────────
DATABASE_URL="postgresql://postgres:sua_senha_aqui@localhost:5432/dbtestejunior"

# ─── Admin (seed inicial) ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=troque_por_uma_senha_forte

# ─── Frontend (embutida no JS em tempo de build pelo Vite) ───────────────────
# Em produção com Docker: use o endereço público da sua API
# Exemplo local:  http://localhost:3333/api
# Exemplo prod:   https://api.seudominio.com/api
VITE_API_URL=http://localhost:3333/api
